#!/usr/bin/env bash
set -euo pipefail

script_dir="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
command -v git >/dev/null 2>&1 || {
  printf '[mux/init] error: required command not found: git\n' >&2
  exit 1
}

repo_root="$(git -C "$script_dir" rev-parse --show-toplevel 2>/dev/null)" || {
  printf '[mux/init] error: could not locate the Git repository root from %s\n' "$script_dir" >&2
  exit 1
}

bash "$repo_root/scripts/initialize-dev.sh"

# Keep tools installed by initialize-dev.sh available to this shell when this
# script is sourced, and to future login/interactive shells via a generated file.
env_file="${MYRIALE_DEV_ENV_FILE:-$HOME/.config/myriale/dev-path.sh}"
mkdir -p "$(dirname -- "$env_file")" "$HOME/.local/bin"
cat > "$env_file" <<'EOF'
# Generated by Myriale .mux/init. Source this file to use installed development tools.
export DOTNET_ROOT="${DOTNET_ROOT:-$HOME/.dotnet}"
export PATH="$HOME/.local/bin:$DOTNET_ROOT:$HOME/.dotnet/tools:$PATH"
EOF

export DOTNET_ROOT="${DOTNET_ROOT:-$HOME/.dotnet}"
export PATH="$HOME/.local/bin:$DOTNET_ROOT:$HOME/.dotnet/tools:$PATH"

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  printf '[mux/init] tool environment written to %s\n' "$env_file"
  printf '[mux/init] run `source %q` to load it into the current shell.\n' "$env_file"
fi
